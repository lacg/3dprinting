{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1180px"
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{ "slug": "ras-paper",          "name": "Paper",          "color": "#F4F2EE" },
				{ "slug": "ras-surface",        "name": "Surface",        "color": "#FBFAF7" },
				{ "slug": "ras-ink",            "name": "Ink",            "color": "#2B2722" },
				{ "slug": "ras-muted",          "name": "Muted",          "color": "#6E665C" },
				{ "slug": "ras-line",           "name": "Hairline",       "color": "#DED8CC" },
				{ "slug": "ras-graphite",       "name": "Graphite",       "color": "#202020" },
				{ "slug": "ras-warm-charcoal",  "name": "Warm Charcoal",  "color": "#241F1B" },
				{ "slug": "ras-aluminum",       "name": "Aluminum",       "color": "#BFBFB6" },
				{ "slug": "ras-greige",         "name": "Greige",         "color": "#C4B9A6" },
				{ "slug": "ras-light",          "name": "Light",          "color": "#EDEAE4" },
				{ "slug": "ras-gold",           "name": "Gold",           "color": "#B8893B" },
				{ "slug": "ras-gold-light",     "name": "Gold Light",     "color": "#CDA35A" },
				{ "slug": "ras-gold-dark",      "name": "Gold Dark",      "color": "#8A6526" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"name": "Manrope",
					"slug": "manrope",
					"fontFamily": "Manrope, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Manrope[wght].woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "x-small",  "name": "X-Small",  "size": "0.9375rem", "fluid": false },
				{ "slug": "small",    "name": "Small",    "size": "1.125rem",  "fluid": false },
				{ "slug": "medium",   "name": "Medium",   "size": "1.25rem",   "fluid": { "min": "1.1875rem", "max": "1.25rem" } },
				{ "slug": "large",    "name": "Large",    "size": "1.75rem",   "fluid": { "min": "1.5625rem", "max": "1.75rem" } },
				{ "slug": "x-large",  "name": "X-Large",  "size": "2.625rem",  "fluid": { "min": "2.25rem",   "max": "2.625rem" } },
				{ "slug": "xx-large", "name": "XX-Large", "size": "3.75rem",   "fluid": { "min": "2.875rem",  "max": "3.75rem" } },
				{ "slug": "display",  "name": "Display",  "size": "4.75rem",   "fluid": { "min": "3.4375rem", "max": "4.75rem" } }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vw", "vh" ],
			"spacingSizes": [
				{ "slug": "20", "name": "1", "size": "0.5rem" },
				{ "slug": "30", "name": "2", "size": "1rem" },
				{ "slug": "40", "name": "3", "size": "1.5rem" },
				{ "slug": "50", "name": "4", "size": "2.5rem" },
				{ "slug": "60", "name": "5", "size": "4rem" },
				{ "slug": "70", "name": "6", "size": "6rem" },
				{ "slug": "80", "name": "7", "size": "8rem" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--ras-paper)",
			"text": "var(--wp--preset--color--ras-ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--manrope)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"lineHeight": "1.6",
			"letterSpacing": "0"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": { "left": "1.25rem", "right": "1.25rem" }
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--manrope)",
					"fontWeight": "600",
					"lineHeight": "1.14",
					"letterSpacing": "-0.012em"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)", "fontWeight": "700" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--ras-ink)" },
				":hover": { "color": { "text": "var(--wp--preset--color--ras-muted)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--ras-gold)",
					"text": "#ffffff"
				},
				"border": { "radius": "6px" },
				"spacing": { "padding": { "top": "0.85rem", "bottom": "0.85rem", "left": "1.6rem", "right": "1.6rem" } },
				"typography": { "fontWeight": "600", "letterSpacing": "0.005em" },
				":hover": { "color": { "background": "var(--wp--preset--color--ras-gold-dark)", "text": "#ffffff" } },
				":focus": { "color": { "background": "var(--wp--preset--color--ras-gold-dark)", "text": "#ffffff" } }
			}
		}
	}
}
